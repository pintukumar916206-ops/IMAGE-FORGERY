# Database Configuration
# DB_PATH=forgery.sqlite

# Security (Required for Production)
# Generate a real 32-character key for production!
SECRET_KEY=dev-secret-key-that-is-at-least-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-secure

# Analyst Credentials
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=change-me-analyst-secure

# Monitoring & Logs
DEBUG=False
PORT=8000
HOST=0.0.0.0

# Detection Thresholds (Expert Calibrated)
ELA_THRESHOLD=8.0
ELA_JPEG_QUALITY=90
REPORT_EXPIRATION_HOURS=24
SIFT_RATIO_THRESHOLD=0.65
SIFT_MIN_MATCHES=10
SIFT_MIN_INLIERS=5
SIFT_CLUSTER_DISTANCE=2.2
SIFT_MIN_SPATIAL_DISTANCE=20
SIFT_MAX_SPATIAL_DISTANCE=500
ENTROPY_THRESHOLD=5.0
