# Backend server
HOST=0.0.0.0
PORT=8000
DEBUG=False
UPLOAD_DIR=uploads
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Security (MUST CHANGE IN PRODUCTION)
API_KEY_REQUIRED=true
SECRET_KEY=change-this-in-production-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-secure
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=change-me-analyst-secure

# Processing and storage
SYNC_MODE=False
REPORT_EXPIRATION_HOURS=24

# Detection thresholds
ELA_THRESHOLD=25.0
ELA_JPEG_QUALITY=90
SIFT_RATIO_THRESHOLD=0.65
SIFT_MIN_MATCHES=10
SIFT_MIN_INLIERS=5
SIFT_CLUSTER_DISTANCE=2.2
SIFT_MIN_SPATIAL_DISTANCE=20
SIFT_MAX_SPATIAL_DISTANCE=500
ENTROPY_THRESHOLD=5.0
